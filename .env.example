# ============================================
# AVTO BOT PRO — Muhit o'zgaruvchilari (Environment Variables)
# ============================================
# Bu faylni ".env" deb nusxa oling va qiymatlarni to'ldiring.
# .env faylini hech kimga bermang va git'ga commit qilmang!


# ============================================
# 1. TELEGRAM BOT (MAJBURIY)
# ============================================

# BotFather'dan olingan bot tokeni
# https://t.me/BotFather → /newbot → tokeni nusxa oling
BOT_TOKEN=1234567890:AAEXAMPLE_TOKEN_FROM_BOTFATHER

# Telegram API ID va HASH (https://my.telegram.org → API development tools)
# Bular GramJS userbot uchun ishlatiladi
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Bot adminining Telegram chat ID raqami (raqam, @username emas!)
# Bilish uchun: @userinfobot ga /start yuboring
ADMIN_ID=123456789


# ============================================
# 2. SERVER
# ============================================

# Express server porti (self-ping uchun)
# VPS'da odatda 3000, Render avtomatik tanlaydi
PORT=3000


# ============================================
# 3. BACKUP TIZIMI (TAVSIYA ETILADI)
# ============================================

# Backup uchun admin akkaunt session string (GramJS StringSession)
# Bot DB faylini "Saved Messages" ga shifrlangan holda yuboradi
# Bo'sh qoldirsangiz backup ishlamaydi (lekin bot ishlaydi)
ADMIN_SESSION=

# Backup faylini shifrlash uchun maxfiy kalit (kamida 16 belgi)
# Ixtiyoriy uzun va murakkab parol qo'ying
BACKUP_SECRET=mySuperSecretKey_change_me_2024_minimum_16_chars


# ============================================
# 4. REFERRAL TIZIMI (IXTIYORIY)
# ============================================

# Bot username'i (referal linklari uchun)
# Default: @Foydasizku_bot (avtomatik)
BOT_PROMO_USERNAME=@your_bot_username

# Referal botning username'i (boshqa bot ishlatish uchun)
# Bo'sh qoldirsa BOT_PROMO_USERNAME ishlatiladi
REFERRAL_BOT_USERNAME=


# ============================================
# 5. TELEGRAM ULANISH (IXTIYORIY)
# ============================================

# WebSocket Secure (WSS) ishlatish: 1 (Render/Cloud uchun yaxshi), 0 (VPS uchun TCP yaxshi)
# VPS'da: 0 qiymat tezroq ishlaydi
# Render'da: 1 (default)
AUTH_USE_WSS=0

# Telegram MTProto Proxy (faqat sertifikatlangan davlatlardan ishlaganda kerak)
# Bo'sh qoldirsa proxy ishlatilmaydi
TELEGRAM_PROXY_HOST=
TELEGRAM_PROXY_PORT=443
TELEGRAM_PROXY_SECRET=


# ============================================
# 6. GRAMJS DEVICE MA'LUMOTLARI (IXTIYORIY)
# ============================================
# Default qiymatlar yetarli, lekin xohlasangiz o'zgartirishingiz mumkin

TG_DEVICE_MODEL=AvtoBotPro_v2
TG_SYSTEM_VERSION=Windows 10y
TG_APP_VERSION=Telegram Desktop 1.0.0


# ============================================
# 7. RENDER.COM SOZLAMALARI (FAQAT RENDER UCHUN)
# ============================================
# Bu o'zgaruvchilar Render avtomatik o'rnatadi - VPS'da kerak emas

# Render avtomatik o'rnatadi
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
# RENDER_SERVICE_NAME=your-service-name


# ============================================
# 8. DATABASE (FAQAT POSTGRESQL UCHUN, ISHLATILMAYDI)
# ============================================
# Hozirgi loyiha SQLite ishlatadi, bu o'zgaruvchi kerak emas
# Faqat agar PostgreSQL'ga o'tmoqchi bo'lsangiz

# DATABASE_URL=postgresql://user:password@host:5432/dbname


# ============================================
# 9. NODE_ENV (IXTIYORIY)
# ============================================
# production yoki development
# production: log kamroq, optimizatsiyalar yoqilgan
NODE_ENV=production
